{
    "name": "pablo/agenda",
    "description": "Proyecto agenda con composer",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Agenda\\Controllers\\": "src/Controllers/",
            "Agenda\\Models\\": "src/Models/",
            "Agenda\\Core\\": "src/Core/",
            "Agenda\\Repositories\\": "src/Repositories/",
            "Agenda\\Request\\": "src/Request",
            "Agenda\\Services\\": "src/Services"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "symfony/routing": "^7.4",
        "stefangabos/zebra_pagination": "^2.4"
    }
}
